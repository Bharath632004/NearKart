# ═══════════════════════════════════════════════════
#  NearKart – Environment Variables Template
#  Copy to .env and fill real values
# ═══════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_DB=nearkart
POSTGRES_USER=nearkart_user
POSTGRES_PASSWORD=nearkart_pass

# ── Spring Profiles ─────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_256bit_secret_key_here
JWT_EXPIRATION_MS=86400000

# ── Redis ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Frontend ────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api

# ── Docker Hub (for CI/CD pushes) ───────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_access_token
