# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files with secrets
terraform.tfvars
*.auto.tfvars

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
